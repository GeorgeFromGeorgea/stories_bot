# Stories Bot Configuration
# ========================
# This file contains all required configuration for Stories Bot.
# 
# How to get these values:
#
# 1. BOT_TOKEN
#    - Open Telegram and search for @BotFather
#    - Send /newbot and follow the instructions
#    - Copy the token (looks like: 1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ)
#
# 2. API_ID and API_HASH
#    - Go to https://my.telegram.org/apps
#    - Log in with your phone number
#    - Create a new application (or use existing)
#    - Copy API ID (number) and API Hash (string)
#
# 3. SESSION_NAME
#    - Name for the session file (default: stories_session)
#    - This is created when you first run 'stories-bot login'

# Telegram Bot Token (from @BotFather)
BOT_TOKEN="your_bot_token_here"

# Telegram API credentials (from https://my.telegram.org/apps)
API_ID=12345678
API_HASH="your_api_hash_here"

# Session name for userbot (default: stories_session)
SESSION_NAME="stories_session"
